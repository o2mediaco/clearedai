# Copy to .env.local and fill in. The app runs WITHOUT these (deterministic
# mock agent + mock feeds), but Gemma orchestration and real flight data turn
# on when set.

# OpenRouter — powers the Gemma multi-agent pipeline (Router → Analyst → Comm).
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Model slug OpenRouter routes to. Use a :free Gemma so demo calls cost nothing.
OPENROUTER_MODEL=google/gemma-4-26b-a4b-it:free

# Optional per-role model overrides (default to OPENROUTER_MODEL)
# OPENROUTER_MODEL_ROUTER=
# OPENROUTER_MODEL_ANALYST=
# OPENROUTER_MODEL_COMM=

# Feed mode: "mock" (default — reliable scripted disruption arc for demos)
# or "real" (uses the live APIs below where a key exists, mock otherwise).
FEED_MODE=mock

# FlightAware AeroAPI — real flight status for the flight_status feed.
# https://www.flightaware.com/aeroapi/portal/documentation
AERO_API_KEY=
